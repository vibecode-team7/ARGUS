ARGUS_KEY_TEST=your_test_key_here
ARGUS_KEY_LINUX=your_linux_agent_key_here
ARGUS_KEY_MACOS=your_macos_agent_key_here
ARGUS_KEY_WINDOWS=your_windows_agent_key_here
ARGUS_KEY_DASHBOARD=your_dashboard_key_here

# Optional — high-severity findings trigger an alert to whichever of these
# are set. Leave blank to disable.
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Optional — override SQLite database directory (default: backend/data/)
# ARGUS_DB_DIR=/app/data
